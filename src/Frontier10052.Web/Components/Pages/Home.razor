@page "/"
@implements IAsyncDisposable
@inject IJSRuntime JavaScript

<PageTitle>Frontier 10052 — Enter the Frontier</PageTitle>
<HeadContent>
    <meta name="description" content="Command an aging merchant ship across a living hard-science-fiction frontier where distance, trust, crew, and consequence matter." />
</HeadContent>

<div class="home-cinematic" @ref="_root">
    <section class="cinematic-hero" aria-labelledby="hero-title">
        <img class="intro-plate intro-solar" src="assets/cinematic/solar-pullback.webp" alt="" fetchpriority="high" />
        <img class="intro-plate intro-galaxy" src="assets/cinematic/galaxy-reveal.webp" alt="" fetchpriority="high" />
        <div class="hero-shade" aria-hidden="true"></div>

        <div class="intro-controls" aria-label="Cinematic controls">
            <button type="button" data-skip-intro>Skip intro</button>
            <button type="button" data-sound-toggle aria-pressed="false">Sound off</button>
        </div>

        <div class="hero-reveal">
            <h1 id="hero-title"><span>Frontier</span> 10052</h1>
            <p class="sr-only">A hard-science-fiction trading, crew, and civilization simulation.</p>
            <div class="hero-actions" aria-label="Start exploring">
                <a class="cinematic-action primary" href="/play">Play now</a>
                <button class="cinematic-action" type="button" data-open-trailer>Watch trailer</button>
                <a class="cinematic-action" href="/universe">The universe</a>
            </div>
        </div>
    </section>

    <section class="scale-prologue" aria-labelledby="scale-title">
        <p class="section-index">01 · Distance</p>
        <h2 id="scale-title">A message cannot outrun the ship carrying it.</h2>
        <p>Prices age. Warrants travel. People wait. Every departure changes what you will know when you arrive.</p>
    </section>

    <section class="living-journey" id="living-frontier" data-living-journey aria-labelledby="living-title">
        <div class="living-stage" aria-hidden="true">
            <img src="assets/cinematic/living-frontier.webp" alt="" data-living-image />
        </div>
        <div class="living-narrative">
            <article class="living-beat">
                <p class="section-index">02 · Departure</p>
                <h2 id="living-title">Nothing waits for the camera.</h2>
                <p>Cargo loaders retract. Thrusters answer. Escorts form up while a mining convoy clears the station behind you.</p>
            </article>
            <article class="living-beat align-right">
                <p class="section-index">03 · The ship</p>
                <h2>Your vessel is home, collateral, and witness.</h2>
                <p>Repairs leave scars. Crew remember dangerous shortcuts. Every module trades cargo, comfort, heat, law, or survival against something else.</p>
                <a class="text-route" href="/ships">Explore the ships</a>
            </article>
            <article class="living-beat">
                <p class="section-index">04 · Trust</p>
                <h2>The best cargo may be a warning.</h2>
                <p>Carry news between stars. Verify its source. Decide who hears it first—and who profits from arriving too late.</p>
                <a class="text-route" href="/universe">Enter the universe</a>
            </article>
        </div>
    </section>

    <section class="frontier-index" aria-labelledby="explore-title">
        <div class="index-intro">
            <p class="section-index">05 · Explore</p>
            <h2 id="explore-title">One civilization.<br />No single truth.</h2>
            <p>Follow the systems, institutions, ships, and people that keep humanity moving.</p>
        </div>
        <nav class="index-routes" aria-label="Explore Frontier 10052">
            <a href="/factions"><small>01</small><span>Factions</span><b>Power has a travel time</b></a>
            <a href="/star-map"><small>02</small><span>Star map</span><b>Knowledge is never complete</b></a>
            <a href="/crew"><small>03</small><span>Crew</span><b>People are not bonuses</b></a>
            <a href="/colonies"><small>04</small><span>Colonies</span><b>Settlements become history</b></a>
            <a href="/lore"><small>05</small><span>Lore</span><b>Every claim has a source</b></a>
            <a href="/roadmap"><small>06</small><span>Roadmap</span><b>Build the journey, then the galaxy</b></a>
        </nav>
    </section>

    <section class="final-call" aria-labelledby="final-title">
        <img src="assets/cinematic/galaxy-reveal.webp" alt="" loading="lazy" />
        <div>
            <p class="section-index">Milky Way · Andromeda</p>
            <h2 id="final-title">The frontier is not empty.</h2>
            <p>It is waiting for news, medicine, machinery, witnesses, and someone willing to carry the consequences.</p>
            <a class="cinematic-action primary" href="/play">Enter the frontier</a>
        </div>
    </section>

    <dialog class="trailer-dialog" data-trailer aria-labelledby="trailer-title">
        <div class="trailer-viewport">
            <img class="trailer-frame active" src="assets/cinematic/solar-pullback.webp" alt="" data-trailer-frame data-caption="Eight thousand years from now, distance still decides what is true." />
            <img class="trailer-frame" src="assets/cinematic/galaxy-reveal.webp" alt="" data-trailer-frame data-caption="Humanity crossed the stars. Andromeda became the promised frontier." />
            <img class="trailer-frame" src="assets/cinematic/living-frontier.webp" alt="" data-trailer-frame data-caption="You carry cargo, news, debt, and the lives of the people aboard." />
            <div class="trailer-shade" aria-hidden="true"></div>
            <div class="trailer-copy">
                <p>Official concept trailer</p>
                <h2 id="trailer-title">Frontier 10052</h2>
                <span data-trailer-caption aria-live="polite">Eight thousand years from now, distance still decides what is true.</span>
            </div>
        </div>
        <div class="trailer-timeline" aria-hidden="true"><span data-trailer-progress></span></div>
        <div class="trailer-controls">
            <button type="button" data-trailer-toggle>Pause</button>
            <span>01:00 · Captions on</span>
            <button type="button" data-close-trailer>Close</button>
        </div>
    </dialog>
</div>

@code {
    private ElementReference _root;
    private IJSObjectReference? _module;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _module = await JavaScript.InvokeAsync<IJSObjectReference>("import", "./js/cinematic.js");
        await _module.InvokeVoidAsync("initializeHome", _root);
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is null) return;
        try
        {
            await _module.InvokeVoidAsync("disposeHome", _root);
            await _module.DisposeAsync();
        }
        catch (JSDisconnectedException)
        {
            // The browser has already disconnected.
        }
    }
}

@page "/universe"
@page "/factions"
@page "/star-map"
@page "/ships"
@page "/colonies"
@page "/crew"
@page "/lore"
@page "/roadmap"
@page "/community"
@inject NavigationManager Navigation

<PageTitle>@_content.PageTitle — Frontier 10052</PageTitle>
<HeadContent>
    <meta name="description" content="@_content.Description" />
</HeadContent>

<article class="editorial-page @($"editorial-{_content.Slug}")">
    <header class="editorial-hero">
        <img src="@_content.Image" alt="" fetchpriority="high" />
        <div class="editorial-shade" aria-hidden="true"></div>
        <div class="editorial-title">
            <p>@_content.Index · @_content.Eyebrow</p>
            <h1>@_content.Title</h1>
            <span>@_content.Lede</span>
        </div>
        <a class="editorial-scroll" href="#feature">Read the transmission</a>
    </header>

    <section class="editorial-intro" id="feature">
        <p class="section-index">@_content.Eyebrow</p>
        <h2>@_content.Statement</h2>
        <div>
            <p>@_content.Description</p>
            <blockquote>@_content.Quote</blockquote>
        </div>
    </section>

    <section class="signature-module" aria-labelledby="module-title">
        <div class="signature-heading">
            <p class="section-index">Field index</p>
            <h2 id="module-title">@_content.ModuleTitle</h2>
        </div>
        <div class="signature-rows">
            @foreach (var row in _content.Rows)
            {
                <article class="@(row.CrewId is null ? null : "crew-editorial-row")">
                    <small>@row.Label</small>
                    @if (row.CrewId is not null)
                    {
                        <CrewPortrait CrewId="@row.CrewId" Variant="editorial" Eager="true" />
                    }
                    <div class="signature-row-copy">
                        <h3>@row.Title</h3>
                        <p>@row.Detail</p>
                        <span>@row.Meta</span>
                    </div>
                </article>
            }
        </div>
    </section>

    <nav class="editorial-next" aria-label="Continue exploring">
        <p>Continue through the frontier</p>
        <a href="@_content.NextPath"><span>@_content.NextLabel</span><small>@_content.NextDetail</small></a>
        <a href="@_content.SecondaryPath"><span>@_content.SecondaryLabel</span><small>@_content.SecondaryDetail</small></a>
    </nav>
</article>


@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Navigation

<div class="site-shell @RouteClass">
    <a class="skip-link" href="#main-content">Skip to content</a>

    <header class="global-header" aria-label="Global navigation">
        <a class="global-wordmark" href="/" aria-label="Frontier 10052 home">
            <span>Frontier</span><b>10052</b>
        </a>
        <div class="global-actions">
            <button class="menu-trigger" type="button" aria-expanded="@_menuOpen" aria-controls="site-menu" @onclick="ToggleMenu">Menu</button>
            <a class="global-play" href="/play">Play now</a>
        </div>
    </header>

    @if (_menuOpen)
    {
        <section class="site-menu" id="site-menu" role="dialog" aria-modal="true" aria-label="Site navigation">
            <div class="site-menu-head">
                <span>Frontier 10052</span>
                <button type="button" @onclick="CloseMenu">Close</button>
            </div>
            <nav aria-label="Main website navigation">
                @foreach (var item in NavigationItems)
                {
                    <NavLink href="@item.Path" Match="@item.Match" @onclick="CloseMenu">
                        <small>@item.Index</small><span>@item.Label</span>
                    </NavLink>
                }
            </nav>
            <p class="site-menu-note">Distance has weight. Trust is playable. The ship remembers.</p>
        </section>
    }

    <main id="main-content">@Body</main>

    @if (!IsLauncher)
    {
        <footer class="global-footer">
            <a class="global-wordmark" href="/"><span>Frontier</span><b>10052</b></a>
            <p>A living frontier where goods, news, law, and people travel at the speed of ships.</p>
            <div><a href="/roadmap">Roadmap</a><a href="/community">Community</a><a href="/play">Play now</a></div>
        </footer>
    }
</div>

@code {
    private bool _menuOpen;

    private static readonly NavigationItem[] NavigationItems =
    [
        new("01", "Home", "/", NavLinkMatch.All),
        new("02", "The universe", "/universe", NavLinkMatch.Prefix),
        new("03", "Factions", "/factions", NavLinkMatch.Prefix),
        new("04", "Star map", "/star-map", NavLinkMatch.Prefix),
        new("05", "Ships", "/ships", NavLinkMatch.Prefix),
        new("06", "Colonies", "/colonies", NavLinkMatch.Prefix),
        new("07", "Crew", "/crew", NavLinkMatch.Prefix),
        new("08", "Lore", "/lore", NavLinkMatch.Prefix),
        new("09", "Roadmap", "/roadmap", NavLinkMatch.Prefix),
        new("10", "Community", "/community", NavLinkMatch.Prefix),
        new("11", "Play now", "/play", NavLinkMatch.Prefix),
    ];

    private string Path => new Uri(Navigation.Uri).AbsolutePath;
    private bool IsLauncher =>
        Path.StartsWith("/play", StringComparison.OrdinalIgnoreCase) ||
        Path.StartsWith("/operations", StringComparison.OrdinalIgnoreCase) ||
        Path.StartsWith("/travel", StringComparison.OrdinalIgnoreCase);
    private string RouteClass => IsLauncher ? "launcher-route" : "website-route";

    protected override void OnInitialized() => Navigation.LocationChanged += OnLocationChanged;

    private void ToggleMenu() => _menuOpen = !_menuOpen;
    private void CloseMenu() => _menuOpen = false;

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs args)
    {
        _menuOpen = false;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose() => Navigation.LocationChanged -= OnLocationChanged;

    private sealed record NavigationItem(string Index, string Label, string Path, NavLinkMatch Match);
}

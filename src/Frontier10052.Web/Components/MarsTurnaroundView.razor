@inject ITurnaroundService Turnaround

@if (_snapshot is not null)
{
    <aside class="operations-rail turnaround-rail" aria-label="Mars turnaround sections">
        <p class="rail-kicker">Second contract</p><h1>Mars turnaround</h1><span class="rail-sequence">Seed @_snapshot.Seed · command @_snapshot.CommandSequence</span>
        <nav>
            @foreach (var step in Steps)
            {
                <button class="@(_active == step.Index ? "active" : null) @(Complete(step.Index) ? "complete" : null)" @onclick="() => _active = step.Index"><small>@step.Index.ToString("00")</small><span>@step.Label</span><i></i></button>
            }
        </nav>
        <div class="rail-route"><small>Offer window</small><b>@Math.Max(0, _snapshot.OfferHoursRemaining) hours remain</b><i></i><b>@(_snapshot.AuthorizedDestination ?? "Pluto or Ceres")</b><span>Unchosen opportunity becomes transformed history.</span></div>
    </aside>

    <main class="operations-workspace turnaround-workspace">
        @if (_error is not null) { <div class="operations-error" role="alert"><b>Command not accepted</b><span>@_error</span><button @onclick="() => _error = null">Dismiss</button></div> }
        @if (_snapshot.DepartureAuthorized)
        {
            <section class="undock-handoff"><p>Second-voyage authority · manifest locked</p><h2>Wayfarer is cleared for @_snapshot.AuthorizedDestination.</h2><span>Debt, service provenance, crew reactions, faction standing, legal exposure, and locked cargo are persisted in schema 3.</span><div><b>Mars Industrial Port</b><i></i><b>@_snapshot.AuthorizedDestination</b></div><a href="/travel">Begin second voyage</a></section>
        }
        else if (_active == 1)
        {
            <section class="workspace-section"><div class="workspace-heading"><p>01 · Inherited lien</p><h2>Wayfarer arrives with 72,000 credits of old ownership still attached.</h2><span>The lien cannot be cleared here. This turnaround decides whether principal and commercial trust improve or deteriorate.</span></div>
                <div class="turnaround-choice-grid"><ActionCard Action="_snapshot.ServiceLienAction" OnChoose="() => Run(() => Turnaround.ServiceLienAsync(PlayerKey))" /><ActionCard Action="_snapshot.DeferLienAction" OnChoose="() => Run(() => Turnaround.DeferLienAsync(PlayerKey))" /></div>
                <div class="turnaround-ledger"><small>Current principal</small><b>@Credits(_snapshot.Lien.Principal)</b><span>@(_snapshot.Lien.Disposition ?? "Decision pending")</span></div>
            </section>
        }
        else if (_active == 2)
        {
            <section class="workspace-section"><div class="workspace-heading"><p>02 · Fuel and repair</p><h2>Time, money, wear, and provenance all leave Mars together.</h2><span>Every started ten-point fuel block consumes one hour. A service that would consume the unselected offer window is blocked.</span></div>
                <div class="ship-debt-strip"><div><small>Fuel</small><b>@_snapshot.Ship.FuelPercent%</b><span>85 credits per point</span></div><div><small>Drive wear</small><b>@_snapshot.Ship.DriveWearPercent%</b><span>@_snapshot.Maintenance.DriveConditionPercent% condition</span></div><div><small>Hull condition</small><b>@_snapshot.Maintenance.HullConditionPercent%</b><span>Persistent service state</span></div><div><small>Available</small><b>@Credits(_snapshot.AvailableCredits)</b><span>@Math.Max(0, _snapshot.OfferHoursRemaining) offer hours remain</span></div></div>
                <div class="refuel-console"><label>Fuel percentage points<input type="number" min="1" max="@(100 - _snapshot.Ship.FuelPercent)" @bind="_fuelPoints" /></label><div><button disabled="@(!CanRefuel || _busy)" @onclick="Refuel">Add fuel</button><p>@RefuelExplanation</p></div></div>
                <div class="turnaround-choice-grid three"><ActionCard Action="_snapshot.CertifiedRepairAction" OnChoose="() => Run(() => Turnaround.RepairAsync(PlayerKey, RepairService.Certified))" /><ActionCard Action="_snapshot.FieldRepairAction" OnChoose="() => Run(() => Turnaround.RepairAsync(PlayerKey, RepairService.IlyaFieldService))" /><ActionCard Action="_snapshot.DeferRepairAction" OnChoose="() => Run(() => Turnaround.RepairAsync(PlayerKey, RepairService.Deferred))" /></div>
            </section>
        }
        else if (_active == 3)
        {
            <section class="workspace-section"><div class="workspace-heading"><p>03 · Crew layover</p><h2>Rest is a route resource, not flavor text.</h2><span>Both plans change every crew member’s persistent fatigue. Ilya’s field repair cost, if chosen, is already visible here.</span></div>
                <div class="turnaround-choice-grid"><ActionCard Action="_snapshot.FullLayoverAction" OnChoose="() => Run(() => Turnaround.RestCrewAsync(PlayerKey, CrewRestService.FullLayover))" /><ActionCard Action="_snapshot.WatchesAction" OnChoose="() => Run(() => Turnaround.RestCrewAsync(PlayerKey, CrewRestService.TurnaroundWatches))" /></div>
                <div class="crew-briefing-list">@foreach (TurnaroundCrewPresentation member in _snapshot.Crew) { <article><small>@member.Role · @member.Assignment</small><h3>@member.Name</h3><dl><div><dt>Loyalty</dt><dd>@member.Loyalty</dd></div><div><dt>Fatigue</dt><dd>@member.Fatigue</dd></div></dl>@if (member.Memories.Count > 0) { <p>@member.Memories[0].Summary</p> }</article> }</div>
            </section>
        }
        else if (_active == 4)
        {
            <section class="workspace-section"><div class="workspace-heading"><p>04 · Competing contracts</p><h2>Lawful relief or gray repair freight.</h2><span>The selected cargo is free and locked. The rejected offer closes for this turnaround, persists as transformed history, and changes Ilya and Tomas differently.</span></div>
                <div class="offer-grid">@foreach (TurnaroundOfferPresentation offer in _snapshot.Offers) { <article class="offer-card @(offer.Status != "Offered" ? "closed" : null)"><small>@offer.Issuer · @offer.Status</small><h3>@offer.Title</h3><p>@offer.Consequence</p><div class="offer-route"><b>Mars</b><i></i><b>@offer.Destination</b></div><dl><div><dt>Cargo</dt><dd>@offer.Quantity t · @offer.Commodity</dd></div><div><dt>Route</dt><dd>@offer.RouteHours h · −@offer.FuelCost% fuel · +@offer.DriveWear% wear</dd></div><div><dt>Deadline</dt><dd>@offer.DeadlineHours h · @offer.DeadlineLabel</dd></div><div><dt>Reward / claim</dt><dd>+@Credits(offer.Reward) / −@Credits(offer.FailurePenalty)</dd></div><div><dt>Canonical crisis</dt><dd>@offer.Encounter</dd></div><div><dt>Crew conflict</dt><dd>@offer.CrewReaction</dd></div></dl><button aria-label="Select @offer.Title" disabled="@(!offer.SelectAction.IsAvailable || _busy)" @onclick="() => Run(() => Turnaround.SelectContractAsync(PlayerKey, new ContractId(offer.Id)))">@offer.SelectAction.Label</button><p class="control-explanation">@offer.SelectAction.Explanation</p></article> }</div>
            </section>
        }
        else
        {
            <section class="workspace-section"><div class="workspace-heading"><p>05 · Departure review</p><h2>Nothing leaves Mars implicit.</h2><span>Debt, service, crew rest, cargo, fuel, and drive margin must all be resolved before the second manifest locks.</span></div>
                <div class="readiness-list">@foreach (TurnaroundRequirement item in _snapshot.DepartureRequirements) { <div class="@(item.Complete ? "complete" : null)"><i></i><span><b>@item.Label</b><small>@item.Detail</small></span></div> }</div>
                <div class="faction-settlement">@foreach (TurnaroundFactionPresentation faction in _snapshot.Factions) { <span>@faction.Name <b>@faction.Standing.ToString("+#;-#;0")</b></span> }<span>Legal exposure <b>@_snapshot.LegalExposure</b></span></div>
                <div class="authorize-action"><button disabled="@(!_snapshot.DepartureAction.IsAvailable || _busy)" @onclick="() => Run(() => Turnaround.AuthorizeDepartureAsync(PlayerKey))">@_snapshot.DepartureAction.Label</button><p><b>@_snapshot.DepartureAction.Consequence</b><br />@_snapshot.DepartureAction.Explanation</p></div>
            </section>
        }
    </main>

    <aside class="manifest-panel turnaround-manifest" aria-label="Persistent turnaround manifest and finances"><div class="manifest-commander"><span>@_snapshot.Initials</span><p><b>@_snapshot.Callsign</b><small>@_snapshot.LocationName · @_snapshot.GameTimeLabel</small></p></div><section><p>Wayfarer manifest</p><div class="hold-meter"><span style="width:@CargoPercent%"></span></div><b>@_snapshot.Ship.CargoLoaded / @_snapshot.Ship.CargoCapacity t</b><small>@_snapshot.Ship.CargoAvailable tonnes free</small></section><section class="manifest-finance"><div><small>Available</small><b>@Credits(_snapshot.AvailableCredits)</b></div><div><small>Inherited lien</small><b>@Credits(_snapshot.Lien.Principal)</b></div><div><small>Legal exposure</small><b>@_snapshot.LegalExposure</b></div></section><section><p>Last consequence</p><small>@_snapshot.LastOutcome</small></section><footer><span>@_snapshot.ContentPackVersion</span><span>Schema @_snapshot.SchemaVersion</span><span>Command @_snapshot.CommandSequence</span></footer></aside>
}

@code {
    [Parameter, EditorRequired] public TurnaroundSnapshot InitialSnapshot { get; set; } = null!;
    [Parameter, EditorRequired] public string PlayerKey { get; set; } = string.Empty;
    private TurnaroundSnapshot? _snapshot;
    private int _active = 1;
    private int _fuelPoints = 10;
    private bool _busy;
    private string? _error;
    private static readonly (int Index, string Label)[] Steps = [(1, "Lien"), (2, "Ship"), (3, "Crew"), (4, "Contracts"), (5, "Departure")];
    protected override void OnInitialized() { _snapshot = InitialSnapshot; if (_snapshot.DepartureAuthorized) _active = 5; }
    private decimal CargoPercent => _snapshot is null ? 0 : _snapshot.Ship.CargoLoaded * 100m / _snapshot.Ship.CargoCapacity;
    private bool Complete(int step) => step switch { 1 => _snapshot?.Lien.Disposition is not null, 2 => _snapshot?.Maintenance.RepairDecision != "Pending", 3 => _snapshot?.DepartureRequirements.Single(item => item.Label == "Crew rest").Complete == true, 4 => _snapshot?.Offers.Any(item => item.Status == "Accepted") == true, 5 => _snapshot?.DepartureAuthorized == true, _ => false };
    private bool CanRefuel => RefuelBlocker is null;
    private string RefuelExplanation => RefuelBlocker ?? $"Costs {Credits(_fuelPoints * 85L)} and takes {(_fuelPoints + 9) / 10} hour(s).";
    private string? RefuelBlocker => _snapshot is null ? "Turnaround state unavailable." : _fuelPoints <= 0 ? "Choose at least one fuel point." : _snapshot.Ship.FuelPercent + _fuelPoints > 100 ? $"Only {100 - _snapshot.Ship.FuelPercent} fuel points fit." : _fuelPoints * 85L > _snapshot.AvailableCredits ? "Available credits are insufficient." : _snapshot.Offers.All(item => item.Status == "Offered") && ((_fuelPoints + 9) / 10) > _snapshot.OfferHoursRemaining ? "This refuel would expire both offers before selection." : null;
    private Task Refuel() => CanRefuel ? Run(() => Turnaround.RefuelAsync(PlayerKey, _fuelPoints)) : Task.CompletedTask;
    private async Task Run(Func<ValueTask<CommandResult<TurnaroundSnapshot>>> command) { if (_busy) return; _busy = true; _error = null; CommandResult<TurnaroundSnapshot> result = await command(); _busy = false; if (result.IsSuccess) _snapshot = result.Value; else _error = result.Error?.Message; }
    private static string Credits(long value) => $"{value:N0} cr";
}
